# Public Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase configuration
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only manual refund account encryption.
# JSON object of version -> base64-encoded 32-byte AES key, for example {"1":"..."}.
REFUND_ACCOUNT_ENCRYPTION_KEYS=
REFUND_ACCOUNT_ACTIVE_KEY_VERSION=1
# Independent base64-encoded key (at least 32 bytes) used only for HMAC fingerprints.
REFUND_ACCOUNT_FINGERPRINT_KEY=

# Manual shipping fee charged once per customer shipment request.
SHIPPING_FEE_AMOUNT=3500

# Kakao OIDC server configuration
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_OIDC_REDIRECT_URI=

# PortOne V2 public configuration
NEXT_PUBLIC_PORTONE_STORE_ID=
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=
NEXT_PUBLIC_PORTONE_WEBHOOK_URL=
VITE_PORTONE_STORE_ID=
VITE_PORTONE_CHANNEL_KEY=
VITE_PORTONE_CARD_CHANNEL_KEY=
VITE_PORTONE_KAKAOPAY_CHANNEL_KEY=
VITE_PORTONE_VIRTUAL_ACCOUNT_CHANNEL_KEY=
VITE_PORTONE_WEBHOOK_URL=

# PortOne V2 server-only configuration
PORTONE_STORE_ID=
PORTONE_API_SECRET=
PORTONE_WEBHOOK_SECRET=
PORTONE_CHANNEL_MODE=

# Entry gate and deployment metadata
ENTRY_GATE_SECRET=
NEXT_PUBLIC_DEPLOY_VERSION=

# Optional owner and business configuration
OWNER_MODE_PIN=
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_EMAIL=
