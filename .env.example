# Supabase Project Settings > API에서 확인합니다.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# 카카오 OIDC 서버 콜백 전용 값입니다. Client Secret은 절대 NEXT_PUBLIC_으로 노출하지 마세요.
# 인가 scope는 코드에서 생략하며 Kakao Developers에 실제 설정된 항목만 적용됩니다.
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_login_client_secret
KAKAO_OIDC_REDIRECT_URI=http://localhost:3000/api/auth/kakao/oidc

# 기존 프로젝트가 legacy anon key만 제공할 때 사용할 수 있습니다.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key

# 아래 값은 카카오 회원정보 동기화와 운영자 계정 관리에 사용하는 서버 전용 값입니다.
# SUPABASE_SECRET_KEY와 비밀번호에는 절대로 NEXT_PUBLIC_ 접두사를 붙이지 마세요.
SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_your_server_only_key
# legacy 프로젝트에서는 SUPABASE_SERVICE_ROLE_KEY를 대신 사용할 수 있습니다.
# SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key
# OPERATOR01_ID=replace_with_the_first_operator_id
# OPERATOR01_PASSWORD=replace_with_a_unique_password_of_12_or_more_chars
# OPERATOR02_ID=replace_with_the_second_operator_id
# OPERATOR02_PASSWORD=replace_with_a_unique_password_of_12_or_more_chars
