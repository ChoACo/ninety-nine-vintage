# Supabase Project Settings > API에서 확인합니다.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# 카카오 OIDC 서버 콜백 전용 값입니다. Client Secret은 절대 NEXT_PUBLIC_으로 노출하지 마세요.
# 인가 scope는 코드에서 생략하며 Kakao Developers에 실제 설정된 항목만 적용됩니다.
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_login_client_secret
KAKAO_OIDC_REDIRECT_URI=http://localhost:3000/api/auth/kakao/oidc

# 기존 프로젝트가 legacy anon key만 제공할 때 사용할 수 있습니다.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key

# 아래 값은 카카오 회원정보 동기화와 서버 운영에 사용하는 서버 전용 값입니다.
# SUPABASE_SECRET_KEY에는 절대로 NEXT_PUBLIC_ 접두사를 붙이지 마세요.
SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_your_server_only_key
# legacy 프로젝트에서는 SUPABASE_SERVICE_ROLE_KEY를 대신 사용할 수 있습니다.
# SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key

# 총책임자 전용 모드의 서버 전용 PIN입니다. 실제 값은 Vercel encrypted env에만
# 저장하고 VITE_ 또는 NEXT_PUBLIC_ 접두사를 절대 붙이지 마세요.
# OWNER_MODE_PIN=your_private_owner_pin
# PG 심사 및 전자상거래 고객지원 표시용 실제 연락처
NEXT_PUBLIC_BUSINESS_PHONE=0507-1494-3519
NEXT_PUBLIC_BUSINESS_EMAIL=ninety-nine@kakao.com

# PortOne V2 테스트/운영 공통 공개 연동값입니다.
# Store ID는 PG MID(iamporttest_3)가 아니라 포트원 콘솔의 store-... 값입니다.
VITE_PORTONE_STORE_ID=store-your-portone-v2-store-id
VITE_PORTONE_CHANNEL_KEY=channel-key-your-test-channel-key
# 결제수단별 채널이 따로 있으면 아래 값을 사용하고, 없으면 위 기본 채널로 폴백합니다.
# VITE_PORTONE_CARD_CHANNEL_KEY=channel-key-your-card-channel
# VITE_PORTONE_VIRTUAL_ACCOUNT_CHANNEL_KEY=channel-key-your-vbank-channel
# VITE_PORTONE_KAKAOPAY_CHANNEL_KEY=channel-key-your-kakaopay-channel
VITE_PORTONE_WEBHOOK_URL=https://www.ninety-nine-vintage.store/api/webhook/portone
# 서버에서도 동일 Store ID를 명시적으로 검증하려면 설정할 수 있습니다.
# PORTONE_STORE_ID=store-your-portone-v2-store-id

# 아래 두 값은 서로 다른 서버 전용 비밀값이며 VITE_ 접두사를 붙이면 안 됩니다.
PORTONE_API_SECRET=your_portone_v2_api_secret
PORTONE_WEBHOOK_SECRET=whsec_your_portone_webhook_secret
# 현재 테스트 채널을 강제 검증합니다. 실 연동 전환 시 LIVE로 변경합니다.
PORTONE_CHANNEL_MODE=TEST
