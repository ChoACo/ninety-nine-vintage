{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Codex: Auto Route (Interactive)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\codex-router.ps1",
        "-Prompt",
        "${input:codexPrompt}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "Codex: Auto Route (One Shot)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\codex-router.ps1",
        "-NonInteractive",
        "-Prompt",
        "${input:codexPrompt}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    }
  ],
  "inputs": [
    {
      "id": "codexPrompt",
      "type": "promptString",
      "description": "Codex에 전달할 작업"
    }
  ]
}
