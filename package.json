{
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd",
      "@tailwindcss/oxide",
      "lightningcss",
      "napi-postinstall"
    ]
  },
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "test": "node --test tests/core/*.test.mjs",
    "verify:browser": "node scripts/verify-local-browser-happy-path.mjs",
    "verify:checkout-browser": "node scripts/verify-local-checkout-browser.mjs",
    "verify:integrations": "node scripts/verify-integrations.mjs",
    "verify:local": "node scripts/verify-local-happy-path.mjs",
    "verify:migrations": "node scripts/verify-migration-parity.mjs",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@portone/browser-sdk": "0.1.9",
    "@portone/server-sdk": "0.19.0",
    "@supabase/supabase-js": "2.110.6",
    "drizzle-orm": "0.45.2",
    "exceljs": "4.4.0",
    "lucide-react": "1.25.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "server-only": "0.0.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3",
    "wrangler": "^4.112.0"
  },
  "type": "module"
}